# AgentHub local configuration
# Copy to .env.local for pnpm dev or to .env for docker compose.
# Generate real secrets before using outside a throwaway local run.

# Database
DATABASE_URL=postgresql://agenthub:agenthub_password@localhost:5432/agenthub
AGENTHUB_DB_DRIVER=postgres
AGENTHUB_PGLITE_DATA_DIR=./data/pglite
POSTGRES_DB=agenthub
POSTGRES_USER=agenthub
POSTGRES_PASSWORD=agenthub_password

# Auth (NextAuth + Casdoor OIDC)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
AUTH_CASDOOR_ISSUER=http://localhost:8000
AUTH_CASDOOR_ID=agenthub
AUTH_CASDOOR_SECRET=agenthub_secret

# Object storage (MinIO / S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=agenthub
S3_ACCESS_KEY_ID=agenthub_minio_user
S3_SECRET_ACCESS_KEY=agenthub_minio_password

# Redis / BullMQ
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Edge-compatible distributed rate limiting.
# Leave blank for local in-memory fallback. Use an Upstash REST URL/token in deployed multi-process environments.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_REDIS_PREFIX=agenthub:rate-limit

# Web search
SEARXNG_BASE_URL=http://localhost:8080

# AI providers
OLLAMA_URL=http://localhost:11434
LMSTUDIO_URL=http://localhost:1234
VLLM_URL=http://localhost:8000

# GitHub Copilot OAuth (device flow public client ID)
GITHUB_COPILOT_CLIENT_ID=Iv1.b507a08c87ecfe98

# Google Gemini OAuth (optional GCP OAuth flow for paid AgentHub plans)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Trust Engine
# Required. Generate with: openssl rand -base64 32
# Use a different value from NEXTAUTH_SECRET.
TRUST_ENGINE_SECRET=

# Local Docker sandbox hardening
AGENTHUB_SANDBOX_IMAGE=python:3.11-slim
AGENTHUB_SANDBOX_SECCOMP_PROFILE=
AGENTHUB_SANDBOX_APPARMOR_PROFILE=

# Observability
LOG_LEVEL=info
SENTRY_ENABLED=0
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
